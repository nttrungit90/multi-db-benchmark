# ============================================================
# Database resource limits — applied equally to ALL databases
# to ensure fair benchmarking. Change these values to test
# how databases behave under different resource constraints.
# ============================================================

# CPU: number of cores (e.g. 1.0, 2.0, 4.0)
DB_CPU_LIMIT=2.0
DB_CPU_RESERVE=1.0

# Memory (e.g. 512M, 1G, 2G, 4G)
DB_MEM_LIMIT=2G
DB_MEM_RESERVE=1G

# MongoDB WiredTiger cache (should be ~50% of DB_MEM_LIMIT)
MONGO_CACHE_SIZE_GB=0.5
